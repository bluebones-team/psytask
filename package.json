{
  "name": "psytask",
  "version": "1.0.0",
  "description": "JavaScript Framework of Psychology Task",
  "scripts": {
    "dev": "bun index.html --hostname=0.0.0.0",
    "build": "bun scripts/build.ts",
    "dev:bench": "bun build:bench --watch",
    "build:bench": "bun build --production --target=browser --outdir=benchmarks/dist benchmarks/index.html benchmarks/*/*.bench.ts benchmarks/*/main.css",
    "format": "prettier --write ."
  },
  "dependencies": {
    "csstype": "^3.1.3"
  },
  "devDependencies": {
    "@jspsych/plugin-html-button-response": "^2.1.0",
    "@jspsych/plugin-html-keyboard-response": "^2.1.0",
    "@types/bun": "^1.2.18",
    "@types/wicg-file-system-access": "^2023.10.6",
    "bun-plugin-dts": "^0.3.0",
    "bun-plugin-dtsx": "^0.9.5",
    "detect-browser": "^5.3.0",
    "jspsych": "^8.2.2",
    "prettier": "^3.6.2",
    "prettier-plugin-jsdoc": "^1.3.3"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-jsdoc"
    ],
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "all"
  }
}
